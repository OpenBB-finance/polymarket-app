{
  "volume_by_tag": {
    "name": "Volume by Tag",
    "description": "Aggregated open-event activity grouped by Polymarket tag. Toggle the metric (24h volume, total volume, open interest) and restrict to events resolving within a window. Click a row to filter the rest of the dashboard.",
    "category": "Polymarket",
    "type": "table",
    "endpoint": "volume_by_tag",
    "gridData": {
      "w": 40,
      "h": 20
    },
    "source": [
      "Polymarket"
    ],
    "params": [
      {
        "paramName": "metric",
        "type": "text",
        "label": "Metric",
        "description": "Activity metric used to rank tags: 24h volume, total volume, or open interest.",
        "value": "volume_24h",
        "options": [
          {
            "label": "24h Volume",
            "value": "volume_24h"
          },
          {
            "label": "Total Volume",
            "value": "volume_total"
          },
          {
            "label": "Open Interest",
            "value": "open_interest"
          }
        ]
      },
      {
        "paramName": "close_within",
        "type": "text",
        "label": "Ends Within",
        "description": "Restrict to events ending within the selected window. Any time includes all open events.",
        "value": "",
        "options": [
          {
            "label": "Any time",
            "value": ""
          },
          {
            "label": "24 hours",
            "value": "1"
          },
          {
            "label": "7 days",
            "value": "7"
          },
          {
            "label": "30 days",
            "value": "30"
          },
          {
            "label": "90 days",
            "value": "90"
          }
        ]
      },
      {
        "paramName": "tag",
        "type": "endpoint",
        "groupById": "tag-options",
        "label": "Tag",
        "description": "Selecting a tag drills this table from volume-by-tag to the tag's top events by volume.",
        "optionsEndpoint": "/options/tag-options",
        "value": "All",
        "show": true,
        "optionsParams": {
          "field": "tag"
        }
      }
    ],
    "data": {
      "table": {
        "showAll": false,
        "enableCharts": false,
        "columnsDefs": [
          {
            "field": "label",
            "headerName": "Tag",
            "cellDataType": "text",
            "chartDataType": "category",
            "pinned": "left",
            "width": 160,
            "renderFn": "cellOnClick",
            "renderFnParams": {
              "actionType": "groupBy",
              "groupBy": {
                "paramName": "tag",
                "valueField": "tag"
              }
            }
          },
          {
            "field": "event_title",
            "headerName": "Event",
            "cellDataType": "text",
            "chartDataType": "category",
            "width": 320
          },
          {
            "field": "volume_24h",
            "headerName": "24h Volume",
            "cellDataType": "number",
            "chartDataType": "series",
            "formatterFn": "int",
            "width": 130
          },
          {
            "field": "volume_total",
            "headerName": "Total Volume",
            "cellDataType": "number",
            "chartDataType": "series",
            "formatterFn": "int",
            "width": 130
          },
          {
            "field": "open_interest",
            "headerName": "Open Interest",
            "cellDataType": "number",
            "chartDataType": "series",
            "formatterFn": "int",
            "width": 135
          },
          {
            "field": "event_count",
            "headerName": "Events",
            "cellDataType": "number",
            "chartDataType": "series",
            "formatterFn": "int",
            "width": 100
          },
          {
            "field": "tag",
            "headerName": "Slug",
            "cellDataType": "text",
            "chartDataType": "category",
            "hide": true
          }
        ]
      }
    }
  },
